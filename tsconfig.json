{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@earendil-works/pi-ai": ["./vendor/pi/packages/ai/src/index.ts"],
			"@earendil-works/pi-ai/oauth": ["./vendor/pi/packages/ai/src/oauth.ts"],
			"@earendil-works/pi-ai/*": ["./vendor/pi/packages/ai/src/*.ts", "./vendor/pi/packages/ai/src/providers/*.ts"],
			"@earendil-works/pi-ai/dist/*": ["./vendor/pi/packages/ai/src/*"],
			"@earendil-works/pi-agent-core": ["./vendor/pi/packages/agent/src/index.ts"],
			"@earendil-works/pi-agent-core/node": ["./vendor/pi/packages/agent/src/node.ts"],
			"@earendil-works/pi-agent-core/*": ["./vendor/pi/packages/agent/src/*"],
			"@earendil-works/pi-coding-agent": ["./vendor/pi/packages/coding-agent/src/index.ts"],
			"@earendil-works/pi-coding-agent/hooks": ["./vendor/pi/packages/coding-agent/src/core/hooks/index.ts"],
			"@earendil-works/pi-coding-agent/*": ["./vendor/pi/packages/coding-agent/src/*"],
			"@earendil-works/pi-orchestrator": ["./vendor/pi/packages/orchestrator/src/index.ts"],
			"@earendil-works/pi-orchestrator/*": ["./vendor/pi/packages/orchestrator/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@earendil-works/pi-tui": ["./vendor/pi/packages/tui/src/index.ts"],
			"@earendil-works/pi-tui/*": ["./vendor/pi/packages/tui/src/*"]
		}
	},
	"include": ["packages/science/src/**/*", "packages/science/test/**/*", "packages/server/src/**/*", "packages/server/test/**/*", "vendor/pi/packages/*/src/**/*"],
	"exclude": ["**/dist/**", "vendor/pi/packages/coding-agent/examples/**", "packages/frontend/**", "frontend/**", "tooling/**"]
}
