{
  "name": "@shying/deepscience",
  "version": "0.0.2",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huang-sh/DeepScience.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/huang-sh/DeepScience#readme",
  "bugs": {
    "url": "https://github.com/huang-sh/DeepScience/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "deepscience": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build --workspace @deepscience/frontend && tsgo -p tsconfig.json && shx rm -rf dist/public && shx mkdir -p dist/public && shx cp -r ../frontend/dist/* dist/public/ && chmod +x dist/cli.js",
    "test": "BIGMODEL_API_KEY=deepscience-test-placeholder ANTHROPIC_API_KEY=deepscience-test-placeholder TSX_TSCONFIG_PATH=../../tsconfig.json node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@hono/node-server": "1.14.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@shying/ds-science": "*",
    "hono": "4.7.11",
    "pi-mcp-adapter": "2.11.0",
    "yaml": "2.9.0"
  }
}
